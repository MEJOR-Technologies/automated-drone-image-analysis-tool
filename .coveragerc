[run]
source = app
relative_files = True
branch = False

omit =
    # --- GUI entry point: pure QApplication bootstrap, no separable logic
    app/__main__.py

    # --- Auto-generated by pyside6-uic and pyside6-rcc (regenerated from .ui/.qrc)
    **/*_ui.py
    **/*_rc.py
    **/resources_rc.py

    # --- Test infrastructure (tests measure themselves at 100% otherwise)
    app/tests/*
    app/tests/**/*
    **/conftest.py

[report]
exclude_also =
    # Runtime-only branches
    if __name__ == .__main__.:
    raise NotImplementedError
    @(abc\.)?abstractmethod
    if TYPE_CHECKING:
    pragma: no cover

show_missing = True
skip_covered = False
skip_empty = True
precision = 1

[html]
directory = htmlcov
